# Copy to .env and fill in.
#
# Web UI
OWW_HOST=0.0.0.0
OWW_PORT=8000
WEB_PORT=8000

# Data root inside the container.
OWW_DATA_DIR=/data

# Optional: host path that backs the in-container /data mount.
# Leave unset to use the portable named docker volume (oww_trainer_data).
# Set to an absolute host path to bind-mount instead - useful when you want the
# downloaded corpora to live on a specific filesystem on the host. The path
# must exist on the host and be writable by the container (uid 0).
# Example for DGX Spark: OWW_DATA_DIR_HOST=/opt/models/openwakeword-trainer
OWW_DATA_DIR_HOST=

# ElevenLabs (optional). Leave blank to disable.
# Get a key at https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=

# Hugging Face token. Required for gated datasets (Common Voice).
# Create a read-only token at https://huggingface.co/settings/tokens
HF_TOKEN=

# Logging level: DEBUG, INFO, WARNING, ERROR
OWW_LOG_LEVEL=INFO

# Workers for sample generation / data loading. 0 = auto.
#   GENERATION_WORKERS: 0 -> min(10, cpu_count)
#   DATALOADER_WORKERS: 0 -> min(8, cpu_count)
OWW_GENERATION_WORKERS=0
OWW_DATALOADER_WORKERS=0

# onnxruntime intra-op threads per Piper worker. workers * this should be near
# physical core count. DGX Spark (20 cores) likes 10 workers * 2 threads = 20.
OWW_PIPER_ORT_THREADS=2

# Run Piper TTS on GPU via onnxruntime-gpu. Each worker process creates its
# own CUDA context (~300-500 MB). Set to false on CPU-only hosts or if you
# want to spare GPU memory for the feature-extraction phase. Default: true.
OWW_PIPER_USE_CUDA=true
