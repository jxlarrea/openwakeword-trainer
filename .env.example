# Copy to .env and fill in.
#
# Web UI
OWW_HOST=0.0.0.0
OWW_PORT=8000
WEB_PORT=8000

# Data root inside the container.
OWW_DATA_DIR=/data

# Optional: host path that backs the in-container /data mount.
# Leave unset to use the portable named docker volume (oww_trainer_data).
# Set to an absolute host path to bind-mount instead - useful when you want the
# downloaded corpora to live on a specific filesystem on the host. The path
# must exist on the host and be writable by the container (uid 0).
# Example for DGX Spark: OWW_DATA_DIR_HOST=/opt/models/openwakeword-trainer
OWW_DATA_DIR_HOST=

# ElevenLabs (optional). Leave blank to disable.
# Get a key at https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=

# Hugging Face token. Required for gated datasets (Common Voice).
# Create a read-only token at https://huggingface.co/settings/tokens
HF_TOKEN=

# Logging level: DEBUG, INFO, WARNING, ERROR
OWW_LOG_LEVEL=INFO

# Build-time knobs. These are read by docker compose during image build.
#   OWW_ORT_BUILD_FROM_SOURCE=auto:
#     - linux/amd64: install the public onnxruntime-gpu wheel
#     - linux/arm64: compile onnxruntime-gpu from source (needed on DGX Spark)
#   Set to true to force a source build on x86_64.
OWW_ORT_BUILD_FROM_SOURCE=auto

# Only used when onnxruntime-gpu is compiled from source.
#   RTX 4090 (Ada): 89
#   DGX Spark GB10 / RTX 50-series Blackwell: 120
#   Multiple arches are allowed, e.g. 89;120, but cost more RAM/time.
OWW_CUDA_ARCHITECTURES=120
OWW_BUILD_PARALLEL=8

# Workers for sample generation / data loading. 0 = auto.
#   GENERATION_WORKERS: 0 -> min(10, cpu_count)
#   DATALOADER_WORKERS: 0 -> min(8, cpu_count)
OWW_GENERATION_WORKERS=0
OWW_DATALOADER_WORKERS=0

# onnxruntime intra-op threads per Piper worker. workers * this should be near
# physical core count. DGX Spark (20 cores) likes 10 workers * 2 threads = 20.
OWW_PIPER_ORT_THREADS=2

# Run Piper TTS on GPU via onnxruntime-gpu. Each worker process creates its
# own CUDA context, so workers are recycled aggressively below to return native
# and CUDA memory after each synth.
OWW_PIPER_USE_CUDA=true

# Recycle Piper workers after this many synths. The process pool is also
# scoped to one voice at a time, so memory is bounded without reloading Piper
# for every sample. Lower this if RAM still grows.
OWW_PIPER_MAX_TASKS_PER_CHILD=250

# Strict mode: clear the Piper voice/ONNX session after every synth. This
# releases memory aggressively but can more than halve throughput.
OWW_PIPER_RELEASE_AFTER_SYNTH=false

# Kokoro is additive high-quality TTS for positives. CUDA is the default; the
# trainer uses Kokoro's custom STFT path to avoid Torch complex-kernel JIT
# issues on brand-new GPUs.
OWW_KOKORO_DEVICE=cuda
